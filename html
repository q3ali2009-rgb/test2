<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Koala Land | أرض الكوالا</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap');
        body { font-family: 'Tajawal', sans-serif; scroll-behavior: smooth; }
        .sidebar { transition: 0.3s; }
        .koala-card:hover { transform: translateY(-10px); transition: 0.3s; }
    </style>
</head>
<body class="bg-gray-50">

    <div id="lock-screen" class="fixed inset-0 bg-amber-100 flex items-center justify-center z-[100]">
        <div class="bg-white p-10 rounded-3xl shadow-2xl text-center max-w-sm w-full mx-4 animate__animated animate__fadeInDown">
            <div class="text-6xl mb-4">🐨</div>
            <h2 class="text-2xl font-bold mb-2">حيّاك الله في عالمنا</h2>
            <p class="text-gray-500 mb-6">المكان اللي يجمع كل أنواع الكوالا</p>
            <input type="password" id="pass" class="w-full border p-3 rounded-xl mb-4 text-center" placeholder="اكتب الباسورد">
            <button onclick="unlock()" class="w-full bg-amber-500 text-white py-3 rounded-xl font-bold hover:bg-amber-600">تفضل اقلط</button>
        </div>
    </div>

    <div id="main-content" class="hidden flex h-screen">
        <aside class="w-64 bg-white shadow-lg h-full p-6 flex flex-col border-l border-gray-100 sidebar">
            <div class="text-2xl font-bold text-amber-600 mb-10 text-center">🐨 كوالا كويت</div>
            <nav class="space-y-4">
                <a href="#" class="block p-3 rounded-lg bg-amber-50 text-amber-700 font-bold">الرئيسية</a>
                <a href="#" class="block p-3 rounded-lg hover:bg-gray-50 transition">عن الكوالا</a>
                <a href="#" class="block p-3 rounded-lg hover:bg-gray-50 transition">وصل حديثاً</a>
                <a href="#" class="block p-3 rounded-lg hover:bg-gray-50 transition">تواصل معنا</a>
            </nav>
            <div class="mt-auto p-4 bg-amber-100 rounded-2xl text-sm">
                💡 جرب تضغط على "إضافة للسلة"
            </div>
        </aside>

        <main class="flex-1 overflow-y-auto p-8">
            <header class="flex justify-between items-center mb-10">
                <h1 class="text-3xl font-bold text-gray-800">تشكيلة الكوالا (40+ شخصية)</h1>
                <div class="relative cursor-pointer" onclick="toggleCart()">
                    <span id="cart-count" class="absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full h-5 w-5 flex items-center justify-center">0</span>
                    <svg class="w-8 h-8 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                </div>
            </header>

            <div id="products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                </div>
        </main>
    </div>

    <div id="cart-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex justify-end">
        <div class="bg-white w-full max-w-md h-full p-8 animate__animated animate__slideInLeft">
            <h2 class="text-2xl font-bold mb-6">سلتك المتروسة</h2>
            <div id="cart-items" class="space-y-4 overflow-y-auto h-2/3"></div>
            <hr class="my-6">
            <div class="text-xl font-bold mb-4">الإجمالي: <span id="total-price">0</span> د.ك</div>
            <button onclick="showPayment()" class="w-full bg-green-600 text-white py-4 rounded-2xl font-bold">الانتقال للدفع الآمن</button>
            <button onclick="toggleCart()" class="w-full mt-2 text-gray-500">إغلاق</button>
        </div>
    </div>

    <script>
        const jobs = ["طيار", "مهندس", "دكتور", "رائد فضاء", "غواص", "شيف", "رسام", "ميكانيكي", "لاعب كرة", "محامي", "مدرس", "بحار", "عازف", "مصور"];
        let cart = [];

        // التحقق من كلمة السر
        function unlock() {
            const pass = document.getElementById('pass').value;
            if(pass === 'alinasser') {
                document.getElementById('lock-screen').classList.add('animate__animated', 'animate__fadeOut');
                setTimeout(() => {
                    document.getElementById('lock-screen').style.display = 'none';
                    document.getElementById('main-content').classList.remove('hidden');
                    loadProducts();
                }, 500);
            } else {
                alert("الباسورد غلط يا الحبيب!");
            }
        }

        // توليد 40+ منتج
        function loadProducts() {
            const grid = document.getElementById('products-grid');
            for(let i=1; i<=44; i++) {
                const job = jobs[i % jobs.length];
                grid.innerHTML += `
                    <div class="bg-white p-4 rounded-3xl shadow-sm koala-card border border-gray-100 animate__animated animate__fadeInUp">
                        <div class="bg-amber-50 h-48 rounded-2xl flex items-center justify-center text-5xl mb-4">🐨</div>
                        <h3 class="font-bold text-lg mb-1">كوالا ${job}</h3>
                        <p class="text-amber-600 font-bold mb-4">15.000 د.ك</p>
                        <button onclick="addToCart('كوالا ${job}', 15)" class="w-full py-2 border-2 border-amber-500 text-amber-500 rounded-xl hover:bg-amber-500 hover:text-white transition">أضف للسلة</button>
                    </div>
                `;
            }
        }

        function addToCart(name, price) {
            cart.push({name, price});
            document.getElementById('cart-count').innerText = cart.length;
            alert("تمت الإضافة! تستاهل");
        }

        function toggleCart() {
            const modal = document.getElementById('cart-modal');
            modal.classList.toggle('hidden');
            renderCart();
        }

        function renderCart() {
            const container = document.getElementById('cart-items');
            const total = document.getElementById('total-price');
            container.innerHTML = cart.map(item => `
                <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                    <span>${item.name}</span>
                    <span class="font-bold">${item.price} د.ك</span>
                </div>
            `).join('');
            total.innerText = cart.reduce((sum, item) => sum + item.price, 0);
        }

        function showPayment() {
            alert("سيتم توجيهك لبوابة الدفع:\n- K-NET\n- VISA\n- MASTERCARD\n\nشكراً لثقتك بنا!");
        }
    </script>
</body>
</html>
