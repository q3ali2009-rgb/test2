<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>متجر كوالا | Koala Shop 🐨</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Tajawal', sans-serif; overflow-x: hidden; }
        .glass-effect { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
        .koala-card { transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .koala-card:hover { transform: scale(1.05) rotate(1deg); }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
    </style>
</head>
<body class="bg-[#fdfcf0]">

    <div id="lockScreen" class="fixed inset-0 z-[100] flex items-center justify-center bg-[#fef3c7]">
        <div class="text-center p-10 bg-white rounded-[40px] shadow-2xl border-4 border-amber-200 animate__animated animate__zoomIn max-w-sm w-full mx-4">
            <div class="text-7xl mb-6">🐨</div>
            <h1 class="text-2xl font-bold text-amber-900 mb-2">يا هلا بالزيّن!</h1>
            <p class="text-amber-700 mb-6">منوّرنا يا الغالي.. ممكن كلمة السر؟</p>
            <input type="password" id="passInput" class="w-full px-6 py-4 rounded-2xl border-2 border-amber-100 focus:border-amber-400 outline-none text-center text-xl transition-all" placeholder="اكتبها هني...">
            <button onclick="checkPassword()" class="mt-6 w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-4 rounded-2xl shadow-lg transition-transform active:scale-95">دخول</button>
            <p id="errorMsg" class="text-red-500 mt-4 hidden">أفا.. جرب مرة ثانية!</p>
        </div>
    </div>

    <div id="mainSite" class="hidden opacity-0 flex h-screen overflow-hidden">
        
        <aside class="w-72 bg-white border-l border-gray-100 h-full flex flex-col p-6 shadow-xl z-20">
            <div class="flex items-center gap-3 mb-10 px-2">
                <span class="text-4xl">🐨</span>
                <h2 class="text-xl font-bold text-amber-900">كوالا ستور</h2>
            </div>
            <nav class="space-y-2 flex-1">
                <a href="#" class="flex items-center gap-3 p-4 rounded-2xl bg-amber-50 text-amber-700 font-bold">🏠 القائمة الرئيسية</a>
                <a href="#" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-gray-50 text-gray-600 transition">📝 حول المنتج</a>
                <a href="#" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-gray-50 text-gray-600 transition">🚚 تتبع الطلبية</a>
                <a href="#" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-gray-50 text-gray-600 transition">📞 تواصل معانا</a>
            </nav>
            <div class="p-4 bg-gray-50 rounded-3xl border border-dashed border-gray-200 text-center">
                <p class="text-xs text-gray-400">جميع الحقوق محفوظة 2026 ©</p>
            </div>
        </aside>

        <main class="flex-1 overflow-y-auto p-8 relative">
            <header class="flex justify-between items-center mb-12 sticky top-0 bg-[#fdfcf0]/80 backdrop-blur-md z-10 py-4">
                <div>
                    <h2 class="text-3xl font-bold text-gray-800">كل أنواع الكوالا 🧸</h2>
                    <p class="text-gray-500">اختر رفيقك الجديد من بين 40+ شخصية</p>
                </div>
                <div class="relative cursor-pointer bg-white p-4 rounded-2xl shadow-sm border border-gray-100" onclick="openCart()">
                    <span id="cartBadge" class="absolute -top-2 -right-2 bg-red-500 text-white text-xs w-6 h-6 rounded-full flex items-center justify-center font-bold">0</span>
                    🛒 <span class="mr-2 font-bold">سلتك</span>
                </div>
            </header>

            <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                </div>
        </main>

        <div id="cartDrawer" class="fixed inset-0 z-50 hidden">
            <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeCart()"></div>
            <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl p-8 flex flex-col animate__animated animate__slideInRight">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-2xl font-bold">سلتك المتروسة</h2>
                    <button onclick="closeCart()" class="text-2xl text-gray-400">&times;</button>
                </div>
                <div id="cartItems" class="flex-1 overflow-y-auto space-y-4">
                    </div>
                <div class="mt-8 pt-6 border-t border-gray-100">
                    <div class="flex justify-between text-xl font-bold mb-6">
                        <span>الإجمالي:</span>
                        <span id="cartTotal">0.000</span><span> د.ك</span>
                    </div>
                    <div class="grid grid-cols-3 gap-3 mb-4">
                        <div class="border p-2 rounded-xl text-center opacity-50"><img src="https://upload.wikimedia.org/wikipedia/commons/d/d6/Visa_2021.svg" class="h-4 mx-auto"></div>
                        <div class="border p-2 rounded-xl text-center opacity-50"><img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" class="h-4 mx-auto"></div>
                        <div class="border p-2 rounded-xl text-center font-bold text-blue-600 border-blue-200 bg-blue-50 text-[10px]">K-NET</div>
                    </div>
                    <button onclick="checkout()" class="w-full bg-green-600 hover:bg-green-700 text-white py-4 rounded-2xl font-bold text-lg shadow-lg transition-all">إتمام عملية الدفع 💳</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 1. نظام الحماية
        function checkPassword() {
            const pass = document.getElementById('passInput').value;
            if(pass === 'alinasser') {
                const lock = document.getElementById('lockScreen');
                lock.classList.add('animate__animated', 'animate__fadeOutUp');
                setTimeout(() => {
                    lock.classList.add('hidden');
                    const main = document.getElementById('mainSite');
                    main.classList.remove('hidden');
                    main.classList.add('animate__animated', 'animate__fadeIn');
                    main.style.opacity = '1';
                }, 500);
            } else {
                document.getElementById('errorMsg').classList.remove('hidden');
                document.getElementById('passInput').classList.add('border-red-500', 'animate__animated', 'animate__shakeX');
                setTimeout(() => document.getElementById('passInput').classList.remove('animate__shakeX'), 500);
            }
        }

        // 2. بيانات المنتجات (40+ منتج)
        const jobs = ["طيار", "مهندس", "دكتور", "رائد فضاء", "شيف ماهر", "غواص", "لاعب كورة", "مدرس", "رسام", "قاضي", "محامي", "رجل إطفاء", "مصور", "عازف عود", "فارس", "بحّار"];
        let cart = [];

        function initProducts() {
            const grid = document.getElementById('productGrid');
            for(let i=1; i<=44; i++) {
                const job = jobs[i % jobs.length];
                const price = (Math.random() * (25 - 10) + 10).toFixed(3);
                grid.innerHTML += `
                    <div class="bg-white rounded-[35px] p-5 koala-card border border-gray-100 shadow-sm hover:shadow-xl animate__animated animate__fadeInUp" style="animation-delay: ${i * 0.05}s">
                        <div class="bg-amber-50 rounded-[25px] h-48 flex items-center justify-center text-6xl mb-4 relative overflow-hidden">
                            <span class="z-10 animate__animated animate__pulse animate__infinite">🐨</span>
                            <div class="absolute inset-0 opacity-10 flex items-center justify-center text-xs overflow-hidden">KOALA KUWAIT KOALA KUWAIT</div>
                        </div>
                        <div class="px-2">
                            <h3 class="font-bold text-gray-800 text-lg mb-1">كوالا ${job}</h3>
                            <p class="text-amber-600 font-bold text-xl mb-4">${price} <span class="text-sm">د.ك</span></p>
                            <button onclick="addToCart('كوالا ${job}', ${price})" class="w-full bg-gray-900 text-white py-3 rounded-2xl hover:bg-amber-500 transition-colors flex items-center justify-center gap-2">
                                <span>أضف للسلة</span>
                                <span class="text-lg">+</span>
                            </button>
                        </div>
                    </div>
                `;
            }
        }

        // 3. نظام السلة
        function addToCart(name, price) {
            cart.push({name, price});
            updateCartUI();
            const btn = event.currentTarget;
            btn.innerHTML = "تمت الإضافة! ✅";
            setTimeout(() => {
                btn.innerHTML = `<span>أضف للسلة</span><span class="text-lg">+</span>`;
            }, 1000);
        }

        function updateCartUI() {
            document.getElementById('cartBadge').innerText = cart.length;
            const itemsContainer = document.getElementById('cartItems');
            const totalContainer = document.getElementById('cartTotal');
            
            itemsContainer.innerHTML = cart.map((item, index) => `
                <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-2xl animate__animated animate__fadeIn">
                    <div class="bg-white w-12 h-12 rounded-xl flex items-center justify-center shadow-sm text-xl">🐨</div>
                    <div class="flex-1 font-bold text-gray-700">${item.name}</div>
                    <div class="text-amber-600 font-bold">${item.price.toFixed(3)}</div>
                    <button onclick="removeItem(${index})" class="text-red-400 hover:text-red-600 text-xl">&times;</button>
                </div>
            `).join('');

            const total = cart.reduce((sum, item) => sum + parseFloat(item.price), 0);
            totalContainer.innerText = total.toFixed(3);
        }

        function removeItem(index) {
            cart.splice(index, 1);
            updateCartUI();
        }

        function openCart() { document.getElementById('cartDrawer').classList.remove('hidden'); }
        function closeCart() { document.getElementById('cartDrawer').classList.add('hidden'); }

        function checkout() {
            if(cart.length === 0) return alert("سلتك فاضية يا الغالي!");
            alert("جاري التحويل لبوابة دفع K-NET الآمنة... 💳🇰🇼");
            location.reload(); // محاكاة لانتهاء العملية
        }

        // تشغيل توليد المنتجات عند التحميل
        initProducts();
    </script>
</body>
</html>
